  "scripts": {
    "bootstrap": "npm i --no-save",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "build:dev": "NODE_ENV=development vite build",
    "postbuild": "node tools/fix-manifest.cjs",
    "prod": "npm run build && cd dist && zip -r ../jira-helper.zip . && cd ..",
    "prod:firefox": "BROWSER=FIREFOX npm run build && cd dist-firefox && zip -r ../jira-helper-firefox.zip . && cd ..",
    "clear": "rm -rf dist dist-firefox",
    "dev": "vite preview",
    "dev:watch": "vite",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --quiet",
    "lint:typescript": "tsc --noEmit",
    "lint": "lint-staged",
    "knip": "knip",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "visual:build": "npm run build-storybook",
    "visual:test": "playwright test --config playwright.config.ts",
    "visual:update": "npm run visual:test -- --update-snapshots",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "cy:open": "cypress open --component",
    "cy:run": "cypress run --component",
    "analyze": "node scripts/analyze-modules.mjs",
    "docs:features": "node scripts/generate-features-doc.mjs",
    "docs:changelog": "node scripts/generate-changelog.mjs",
    "precommit": "node tools/precommit.mjs",
    "precommit:full": "npm run lint:typescript && npm run lint:eslint && npm run test && npm run test:storybook && npm run cy:run"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit",
      "prepare-commit-msg": "bash ./tools/prepare-commit-message.sh ${HUSKY_GIT_PARAMS}"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
