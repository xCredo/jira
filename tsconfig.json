{
	"compilerOptions": {
	"plugins": [{ "name": "typescript-plugin-css-modules" }],
	  "target": "ES2022",                     // Целевая версия JavaScript (ES2022 для поддержки top-level await)
	  "module": "ES2022",                     // Тип модуля (ES2022 для поддержки top-level await)
	  "lib": ["DOM", "ESNext"],                // Библиотеки для браузера и современных возможностей
	  "allowJs": true,                         // Разрешить импорт файлов .js
	  "checkJs": false,                        // Проверять файлы .js
	  "jsx": "react",                          // Поддержка JSX, если используется React
	  "strict": true,                          // Включает строгую проверку типов
	  "esModuleInterop": true,                 // Поддержка импорта модулей CommonJS
	  "skipLibCheck": true,                    // Пропустить проверку типов в зависимостях
	  "forceConsistentCasingInFileNames": true, // Проверка регистра файлов
	  "moduleResolution": "bundler",           // Разрешение модулей для Vite/bundler (поддержка package.json exports)
	  "isolatedModules": true,                 // Убедиться, что каждый файл обрабатывается отдельно
	  "noEmit": true,                          // Отключить генерацию файлов .js
	  "resolveJsonModule": true,               // Разрешить импорт JSON
	  "baseUrl": "./",                        // Базовый путь
	  "paths": {
	    "src/*": ["src/*"],
	    "cypress/*": ["cypress/*"]
	  }
	},
	"include": [
	  "src/**/*",                               // Включить все файлы из папки src
	  "./test/setup.ts",
	  "./cypress/support/**/*"
	],
	"exclude": [
	  "node_modules",                          // Исключить node_modules
	  "dist",                                  // Исключить выходную папку
	]
      }